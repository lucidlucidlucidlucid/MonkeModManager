{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MonkeModManager",
  "version": "0.1.0",
  "identifier": "com.lucid.monkemodmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Monke Mod Manager",
        "width": 800,
        "height": 650,
        "resizable": false,
        "decorations": false,
        "acceptFirstMouse": true

      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
